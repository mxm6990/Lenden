{
  "name": "lenden",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "branding": "npm run dev --prefix vendor/Lenden-Branding",
    "sync-branding": "rm -rf vendor/Lenden-Branding && git clone https://github.com/mxm6990/Lenden-Branding.git vendor/Lenden-Branding && npm install --prefix vendor/Lenden-Branding && npm install",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:doctor": "bash scripts/ios-doctor.sh",
    "ios:install-platform": "xcodebuild -downloadPlatform iOS",
    "ios:run": "npm run ios:sync && npx cap run ios --target=\"iPhone 16\"",
    "ios": "npm run ios:sync && npm run ios:open"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "@lenden/branding": "file:./vendor/Lenden-Branding",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
